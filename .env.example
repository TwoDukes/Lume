# Cyan Dashboard — Environment Variables
# Copy this to .env and fill in your values

# Auth token for the dashboard API and WebSocket connections
# Generate a random string: openssl rand -hex 16
LUME_TOKEN=your-secret-token-here

# OpenClaw gateway URL and token (for action button handlers)
# Leave blank if you're not using OpenClaw
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token

# Port (default: 7777)
# PORT=7777
