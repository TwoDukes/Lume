# Lume — Environment Variables
# Copy this to .env and fill in your values

# Auth token for the dashboard API and WebSocket connections
# Generate a random string: openssl rand -hex 16
LUME_TOKEN=your-secret-token-here

# Password for browser login page auth
LUME_PASSWORD=your-strong-password-here

# Set to "true" if running behind HTTPS (enables secure session cookies)
# SECURE_COOKIES=true

# Restrict CORS to specific origin (default: *)
# CORS_ORIGIN=https://your-domain.com

# OpenClaw gateway integration (optional)
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token

# Port (default: 7777)
# PORT=7777
